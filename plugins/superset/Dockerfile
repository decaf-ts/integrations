# Custom Superset image built from source with the switchable-dashboard patch.
#
# This Dockerfile clones the Apache Superset source, applies the patch scripts
# (materialized by SupersetDashboardEmbedPlugin.install()), builds the SDK and
# frontend, and produces a lean runtime image.
#
# Build context is the integrations/plugins/superset/ directory, which contains:
#   - org_dashboard_embed_superset/  (generated by install())
#   - superset_config.py             (curated runtime config)
#
FROM node:18-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    git python3 python3-pip curl bash \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Clone Superset source
ARG SUPERSET_GIT_URL=https://github.com/apache/superset.git
ARG SUPERSET_GIT_REF=6.1.0
RUN git clone --depth 1 --branch ${SUPERSET_GIT_REF} ${SUPERSET_GIT_URL} /build/superset

# Copy patch scripts (materialized by install())
COPY org_dashboard_embed_superset/patches/ /build/patches/
COPY org_dashboard_embed_superset/build/ /build/build-scripts/

# Apply patch
RUN python3 /build/patches/apply_superset_6_1_patch.py /build/superset

# Verify patch
RUN bash /build/patches/verify_patch.sh /build/superset

# Build SDK
RUN cd /build/superset/superset-embedded-sdk && npm ci && npm run build

# Build frontend
RUN cd /build/superset/superset-frontend && npm ci && npm run build

# ─── Runtime stage ──────────────────────────────────────────────────────
FROM node:18-slim AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv curl bash \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m venv /app/venv
ENV PATH="/app/venv/bin:$PATH"

WORKDIR /app

# Install Superset Python dependencies
RUN pip install --no-cache-dir \
    apache-superset==6.1.0 \
    psycopg2-binary \
    celery \
    redis \
    gunicorn

# Copy built frontend assets from builder
COPY --from=builder /build/superset/superset-frontend/ /app/superset-frontend/

# Copy built SDK
COPY --from=builder /build/superset/superset-embedded-sdk/ /app/superset-embedded-sdk/

# Copy Superset config
COPY superset_config.py /app/

ENV SUPERSET_CONFIG_PATH=/app/superset_config.py
ENV FLASK_APP=superset

EXPOSE 8088

# Initialize Superset
RUN superset db upgrade && \
    superset fab create-admin --username admin --firstname Admin --lastname User --email admin@example.com --password admin || true && \
    superset init

CMD ["gunicorn", "-b", "0.0.0.0:8088", "-w", "4", "--timeout", "120", "superset.app:create_app()"]
