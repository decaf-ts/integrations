{
  "name": "@decaf-ts/integrations",
  "version": "3.0.3",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./*": {
      "types": "./lib/*.d.ts",
      "import": "./lib/*.js"
    }
  },
  "scripts": {
    "build": "rimraf ./lib && tsc -p tsconfig.build.json",
    "test": "jest --coverage --testPathPatterns=\"/tests/unit\" --passWithNoTests --detectOpenHandles",
    "test:integration": "tsx tests/integration/keycloak.test.ts && tsx tests/integration/kibana.test.ts && tsx tests/integration/vault.test.ts && tsx tests/integration/aws-secrets-manager.test.ts && tsx tests/integration/gcp-secret-manager.test.ts && tsx tests/integration/model-secrets.test.ts",
    "clean": "rimraf ./lib ./workdocs/coverage"
  },
  "dependencies": {
    "@decaf-ts/core": "workspace:*",
    "@decaf-ts/crypto": "workspace:*",
    "@decaf-ts/db-decorators": "workspace:*",
    "@decaf-ts/decoration": "workspace:*",
    "aws-sdk": "^2.1691.0",
    "axios": "^1.7.9",
    "keycloak-admin": "^24.0.5",
    "node-fetch": "^3.3.2",
    "tslib": "^2.8.1",
    "uuid": "^11.1.0",
    "@aws-sdk/client-secrets-manager": "^3.758.0",
    "@azure/keyvault-secrets": "^4.9.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "hashicorp-vault": "^0.1.0",
    "onelogin-node": "^0.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
